# Copy to `.env` and adjust. `.env` is gitignored.

NODE_ENV=development

PORT=3000

# Browser frontends allowed to call this API (comma-separated). Production: set real admin URLs.
# In development (NODE_ENV !== production), localhost / 127.0.0.1 on any port is also allowed.
# CORS_ORIGINS=https://admin.bestbond.in,https://bestbond.in,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# SQLite database file (relative to process cwd)
DB_PATH=data.sqlite

# --- Dev Super Admin (skipped when NODE_ENV=production) ---
# 10-digit mobile without country code; seeder uses +91 automatically.
DEV_SUPERADMIN_PHONE=9000000000
DEV_SUPERADMIN_EMAIL=admin@admin.in
DEV_SUPERADMIN_NAME=Admin
# Min 8 characters — mobile Management Login → Super Admin → OTP + this password
DEV_SUPERADMIN_PASSWORD=DevSuperAdmin1!
