# API (Nest) — copy to .env.local for local development.
# On production VPS: copy .env.production.example to .env.production (or .env).
# Never commit real secrets.

NODE_ENV=development

# --- Server ---
PORT=3001

# --- CORS (comma-separated origins, no trailing slash) ---
# In development, localhost origins are also allowed automatically.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Database ---
DB_PATH=data.sqlite
# DATABASE_SYNCHRONIZE=false

# --- JWT ---
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_EXPIRES_IN=24h

# --- Dev Super Admin (ignored when NODE_ENV=production) ---
DEV_SUPERADMIN_PHONE=9000000000
DEV_SUPERADMIN_EMAIL=admin@admin.in
DEV_SUPERADMIN_NAME=Admin
DEV_SUPERADMIN_PASSCODE=111111

# --- Optional: coupon PDF export ---
# Local development auto-detects Puppeteer's browser download or installed Chrome/Chromium.
# Production Linux uses @sparticuz/chromium automatically unless overridden.
# PUPPETEER_SKIP_DOWNLOAD=1
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# A4 pages per Chromium pass when merging batch PDFs (default 1; raise only on large servers)
# COUPON_EXPORT_PDF_CHUNK_SIZE=1
# PUPPETEER_PDF_TIMEOUT_MS=120000

# --- Coupon QR deep links (camera scan → app / store) ---
# COUPON_LINK_BASE_URL=https://api.bestbond.in
# IOS_APP_STORE_URL=https://apps.apple.com/in/app/bestbond-pro-club/id6768066865
# ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.nuvate.bestbond
# APP_DEEP_LINK_SCHEME=bestbond
# IOS_TEAM_ID=J22N5WHHN9
# IOS_BUNDLE_ID=com.nuvate.bestbond
# ANDROID_PACKAGE_NAME=com.nuvate.bestbond
# ANDROID_APP_LINK_SHA256=AA:BB:... (release signing cert, comma-separated)
