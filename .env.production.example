# Production — copy to .env.production on the VPS and replace placeholders.
# Never commit .env.production with real secrets.

NODE_ENV=production

# Must match nginx upstream (3001 when bestbond.in uses 3000)
PORT=3001

# Required in production
CORS_ORIGINS=https://admin.bestbond.in,https://bestbond.in

# Persistent SQLite path (back up regularly)
DB_PATH=/var/lib/reward-system/data.sqlite

DATABASE_SYNCHRONIZE=false

TRUST_PROXY=1

PUPPETEER_SKIP_DOWNLOAD=1
# Linux production uses @sparticuz/chromium by default (no apt/sudo). Override:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_USE_SPARTICUZ=0

JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=24h

# Optional
# COUPON_EXPORT_PDF_CHUNK_SIZE=35
# COUPON_EXPORT_SYNC_MAX=300
# COUPON_EXPORT_VOLUME_SIZE=500
# PUPPETEER_PDF_TIMEOUT_MS=180000

# Coupon QR links served at GET /c/:code (defaults shown)
# COUPON_LINK_BASE_URL=https://api.bestbond.in
# IOS_APP_STORE_URL=https://apps.apple.com/in/app/bestbond-pro-club/id6768066865
# ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.nuvate.bestbond
# APP_DEEP_LINK_SCHEME=bestbond
# IOS_TEAM_ID=J22N5WHHN9
# IOS_BUNDLE_ID=com.nuvate.bestbond
# ANDROID_PACKAGE_NAME=com.nuvate.bestbond
# ANDROID_APP_LINK_SHA256=AA:BB:CC:... (Play App Signing SHA-256, comma-separated)
